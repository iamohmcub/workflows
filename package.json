{
  "name": "@iamohmcub/ai-orchestration",
  "version": "0.1.0",
  "description": "Provider-neutral AI engineering workflow scaffold with agents, phases, runtime events, logs, impact reports, handoffs, and commit metadata.",
  "type": "module",
  "bin": {
    "ai-orchestration": "scripts/ai-workflow.mjs",
    "ai-workflow": "scripts/ai-workflow.mjs"
  },
  "files": [
    ".ai",
    ".github/workflows/ai-workflow.yml",
    "AGENTS.md",
    "COMMANDS.md",
    "README.md",
    "ai-orchestration-map.html",
    "scripts/ai-workflow.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamohmcub/workflows.git"
  },
  "homepage": "https://github.com/iamohmcub/workflows#readme",
  "bugs": {
    "url": "https://github.com/iamohmcub/workflows/issues"
  },
  "scripts": {
    "ai": "node scripts/ai-workflow.mjs",
    "ai:status": "node scripts/ai-workflow.mjs status",
    "ai:init": "node scripts/ai-workflow.mjs init",
    "ai:start": "node scripts/ai-workflow.mjs start-phase",
    "ai:trigger": "node scripts/ai-workflow.mjs trigger",
    "ai:impact": "node scripts/ai-workflow.mjs impact",
    "ai:handoff": "node scripts/ai-workflow.mjs handoff",
    "ai:commit": "node scripts/ai-workflow.mjs commit",
    "ai:commit-check": "node scripts/ai-workflow.mjs commit-check",
    "ai:validate": "node scripts/ai-workflow.mjs validate"
  },
  "keywords": [
    "ai",
    "workflow",
    "sdlc",
    "agents",
    "orchestration"
  ],
  "license": "MIT"
}
